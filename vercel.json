{
  "buildCommand": "cd logibox && npm run build",
  "outputDirectory": "logibox/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/favicon.ico", "destination": "/logibox/dist/favicon.ico" },
    { "source": "/favicon.svg", "destination": "/logibox/dist/favicon.svg" },
    { "source": "/icons.svg", "destination": "/logibox/dist/icons.svg" },
    { "source": "/LOGO LOGIBOX.png", "destination": "/logibox/dist/LOGO LOGIBOX.png" },
    { "source": "/(.*)", "destination": "/logibox/dist/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ]
}