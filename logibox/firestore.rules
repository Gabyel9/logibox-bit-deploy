rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to validate vault ID
    function isValidVaultId(vaultId) {
      return vaultId in ['1', '2', '3'];
    }

    // Helper function to validate user fields for create
    function isValidUserCreate(data) {
      let allowed = [
        'firstName', 'lastName', 'email', 'photoURL',
        'otpDuration', 'otpAutoExpire', 'lastLoginAt',
        'profileBackfilled', 'createdAt', 'provider',
        'lastOtpGeneratedAt_1', 'lastOtpGeneratedAt_2', 'lastOtpGeneratedAt_3'
      ];
      return data.keys().hasOnly(allowed)
        && data.keys().hasAny(['email', 'firstName', 'lastName']);
    }

    // Helper function to validate user fields for update
    function isValidUserUpdate(data) {
      let allowed = [
        'firstName', 'lastName', 'email', 'photoURL',
        'otpDuration', 'otpAutoExpire', 'lastLoginAt',
        'profileBackfilled', 'createdAt', 'provider',
        'lastOtpGeneratedAt_1', 'lastOtpGeneratedAt_2', 'lastOtpGeneratedAt_3'
      ];
      return request.resource.data.keys().hasOnly(allowed);
    }

    // Helper function to validate vault fields
    function isValidVaultData(data) {
      let validStatuses = ['empty', 'assigned', 'otp_active', 'otp_expired', 'completed', 'occupied'];
      let validOtpStatuses = ['active', 'expired'];
      let allowed = [
        'id', 'status', 'enabled',
        'receiverName', 'contactNumber', 'parcelInfo', 'deliveryFee', 'createdAt',
        'otp', 'otpHash', 'otpEncrypted', 'otpStatus', 'otpCreatedAt', 'otpExpiresAt',
        'lastOtpGeneratedAt', 'completedAt'
      ];
      return data.keys().hasOnly(allowed)
        && data.status is string
        && data.status in validStatuses
        && (!('enabled' in data) || data.enabled is bool)
        && (!('otpStatus' in data) || data.otpStatus == null || data.otpStatus in validOtpStatuses);
    }

    // User profile - authenticated users can only access their own
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
        && request.auth.uid == uid
        && isValidUserCreate(request.resource.data);
      allow update: if request.auth != null
        && request.auth.uid == uid
        && isValidUserUpdate(request.resource.data);

      // User's vaults subcollection
      match /vaults/{vaultId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null
          && request.auth.uid == uid
          && isValidVaultId(vaultId)
          && isValidVaultData(request.resource.data);
        allow update: if request.auth != null
          && request.auth.uid == uid
          && isValidVaultId(vaultId)
          && isValidVaultData(request.resource.data);
        allow delete: if request.auth != null && request.auth.uid == uid;
      }

      // User's activityLogs subcollection - append only
      match /activityLogs/{logId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null
          && request.auth.uid == uid
          && request.resource.data.action is string
          && request.resource.data.timestamp is timestamp;
        allow update, delete: if false;
      }
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}